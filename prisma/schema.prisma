generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id         String  @id
  username   String  @unique
  accessCode String? @unique
  notifications Notification[]
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  date        DateTime
  classId     Int?
  class       Class?   @relation(fields: [classId], references: [id])
}

model Assignment {
  id        Int      @id @default(autoincrement())
  title     String
  startDate DateTime
  dueDate   DateTime
  lessonId  Int
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  results   Result[]
}

model Attendance {
  id        Int      @id @default(autoincrement())
  date      DateTime
  present   Boolean
  studentId String
  lessonId  Int
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])
}

model Class {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  capacity      Int
  supervisorId  String?
  gradeId       Int
  announcements Announcement[]
  grade         Grade          @relation(fields: [gradeId], references: [id])
  teacher       Teacher?       @relation(fields: [supervisorId], references: [id])
  events        Event[]
  lessons       Lesson[]
  students      Student[]
}

model Conversation {
  id            Int             @id @default(autoincrement())
  user1Id       String
  user2Id       String
  isClosed      Boolean         @default(false)
  closedBy      String?
  createdAt     DateTime        @default(now())
  messages      DirectMessage[] @relation("ConversationToDirectMessage")

  @@unique([user1Id, user2Id])
}

model Course {
  id               Int                @id @default(autoincrement())
  slug             String             @unique @default("")
  title            String
  description      String
  status           CourseStatus       @default(PENDING)
  createdAt        DateTime           @default(now())
  teacherId        String
  teacher          Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments      CourseEnrollment[]
  reviews          CourseReview[]
  sections         CourseSection[]
}

model CourseEnrollment {
  id         Int      @id @default(autoincrement())
  enrolledAt DateTime @default(now())
  courseId   Int
  studentId  String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
}

model CourseLecture {
  id             Int              @id @default(autoincrement())
  title          String
  videoUrl       String
  order          Int
  sectionId      Int
  section        CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress       CourseProgress[]
}

model CourseProgress {
  id            Int           @id @default(autoincrement())
  completed     Boolean       @default(false)
  lectureId     Int
  studentId     String
  lecture       CourseLecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([lectureId, studentId])
}

model CourseReview {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  courseId  Int
  studentId String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model CourseSection {
  id            Int             @id @default(autoincrement())
  title         String
  order         Int
  courseId      Int
  lectures      CourseLecture[]
  course        Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model DirectMessage {
  id                    Int                     @id @default(autoincrement())
  content               String
  messageType           String                  @default("TEXT")
  commandKey            String?
  commandLabel          String?
  commandUrl            String?
  createdAt             DateTime                @default(now())
  senderId              String
  conversationId        Int
  isRead                Boolean                 @default(false)
  replyToId             Int?
  conversation          Conversation            @relation("ConversationToDirectMessage", fields: [conversationId], references: [id], onDelete: Cascade)
  replyTo               DirectMessage?          @relation("DirectMessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies               DirectMessage[]         @relation("DirectMessageReply")
  reactions             DirectMessageReaction[]
  poll                  Poll?

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([isRead])
}

model DirectMessageReaction {
  id            Int           @id @default(autoincrement())
  messageId     Int
  userId        String
  emoji         String
  message       DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model UserBlock {
  id        Int      @id @default(autoincrement())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Poll {
  id               Int             @id @default(autoincrement())
  question         String
  createdAt        DateTime        @default(now())
  directMessageId  Int?            @unique
  groupMessageId   Int?            @unique
  serverMessageId  String?         @unique
  directMessage    DirectMessage?  @relation(fields: [directMessageId], references: [id], onDelete: Cascade)
  groupMessage     GroupMessage?   @relation(fields: [groupMessageId], references: [id], onDelete: Cascade)
  serverMessage    ServerMessage?  @relation(fields: [serverMessageId], references: [id], onDelete: Cascade)
  options          PollOption[]
  votes            PollVote[]
}

model PollOption {
  id     Int    @id @default(autoincrement())
  text   String
  pollId Int
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes  PollVote[]

  @@index([pollId])
}

model PollVote {
  id        Int      @id @default(autoincrement())
  pollId    Int
  optionId  Int
  userId    String
  createdAt DateTime @default(now())
  poll      Poll      @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([optionId])
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  startTime   DateTime
  endTime     DateTime
  classId     Int?
  class       Class?   @relation(fields: [classId], references: [id])
}

model Exam {
  id        Int      @id @default(autoincrement())
  title     String
  startTime DateTime
  endTime   DateTime
  lessonId  Int
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  results   Result[]
}

model Grade {
  id      Int       @id @default(autoincrement())
  level   Int       @unique
  classes   Class[]
  students  Student[]
}

model GroupChat {
  id           Int            @id @default(autoincrement())
  name         String
  description  String?
  accessCode   String         @unique
  bannerUrl    String?        // Group banner URL (shop item unlock)
  createdAt    DateTime       @default(now())
  createdById  String
  members      GroupMember[]
  messages     GroupMessage[]
}

model GroupMember {
  id          Int       @id @default(autoincrement())
  userId      String
  userRole    String
  username    String
  displayName String
  isOwner     Boolean   @default(false)
  joinedAt    DateTime  @default(now())
  groupId     Int
  lastReadAt  DateTime  @default(now())
  isMuted     Boolean   @default(false)
  group       GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model GroupMessage {
  id                   Int                    @id @default(autoincrement())
  content              String
  messageType          String                 @default("TEXT")
  commandKey           String?
  commandLabel         String?
  commandUrl           String?
  createdAt            DateTime               @default(now())
  senderId             String
  senderUsername       String
  senderRole           String
  groupId              Int
  isRead               Boolean                @default(false)
  replyToId            Int?
  group                GroupChat              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  replyTo              GroupMessage?          @relation("GroupMessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies              GroupMessage[]         @relation("GroupMessageReply")
  reactions            GroupMessageReaction[]
  poll                 Poll?

  @@index([groupId])
  @@index([groupId, createdAt])
  @@index([senderId])
}

model GroupMessageReaction {
  id           Int          @id @default(autoincrement())
  messageId    Int
  userId       String
  emoji        String
  message      GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model Lesson {
  id         Int          @id @default(autoincrement())
  name       String
  day        Day
  startTime  DateTime
  endTime    DateTime
  subjectId  Int
  classId    Int
  teacherId  String
  assignments Assignment[]
  attendances Attendance[]
  exams       Exam[]
  class       Class        @relation(fields: [classId], references: [id])
  subject     Subject      @relation(fields: [subjectId], references: [id])
  teacher     Teacher      @relation(fields: [teacherId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      NotificationType @default(GENERIC)
  entityId  String?
  isRead    Boolean  @default(false)
  isViewed  Boolean  @default(false)
  changes   Json?
  createdAt DateTime @default(now())
  studentId String?
  parentId  String?
  teacherId String?
  adminId   String?
  parent     Parent?  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student    Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher    Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  admin      Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([studentId, isRead])
  @@index([studentId, isViewed])
  @@index([teacherId, isRead])
  @@index([teacherId, isViewed])
  @@index([parentId, isRead])
  @@index([parentId, isViewed])
  @@index([adminId, isRead])
  @@index([adminId, isViewed])
  @@index([type])
}

model Parent {
  id           String         @id
  username     String         @unique
  name         String
  surname      String
  email        String?        @unique
  phone        String         @unique
  address      String
  createdAt    DateTime       @default(now())
  accessCode   String?        @unique
  notifications Notification[]
  students      Student[]
  tickets      Ticket[]
}

model ProfileAccess {
  id        String   @id
  userId    String
  userType  String
  code      String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PublicTicket {
  id                  Int                   @id @default(autoincrement())
  code                String                @unique
  type                String
  subject             String
  description         String
  status              TicketStatus          @default(OPEN)
  createdAt           DateTime              @default(now())
  submitterUserId     String?
  submitterRole       String?
  desiredUsername     String?
  desiredRole         String?
  contactEmail        String?
  messages            PublicTicketMessage[]
}

model PublicTicketMessage {
  id                          Int                           @id @default(autoincrement())
  content                     String
  messageType                 String                        @default("TEXT")
  createdAt                   DateTime                      @default(now())
  isAdminReply                Boolean                       @default(false)
  senderId                    String
  senderRole                  String
  ticketId                    Int
  isRead                      Boolean                       @default(false)
  replyToId                   Int?
  ticket                      PublicTicket                  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  replyTo                     PublicTicketMessage?          @relation("PublicTicketMessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies                     PublicTicketMessage[]         @relation("PublicTicketMessageReply")
  reactions                   PublicTicketMessageReaction[]
}

model PublicTicketMessageReaction {
  id                  Int                 @id @default(autoincrement())
  messageId           Int
  userId              String
  emoji               String
  message             PublicTicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model Result {
  id           Int         @id @default(autoincrement())
  score        Int
  examId       Int?
  assignmentId Int?
  studentId    String
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])
  exam         Exam?       @relation(fields: [examId], references: [id])
  student      Student     @relation(fields: [studentId], references: [id])
}

model Student {
  id               String             @id
  username         String             @unique
  name             String
  surname          String
  email            String?            @unique
  phone            String?            @unique
  address          String
  img              String?
  bloodType        String
  sex              UserSex
  createdAt        DateTime           @default(now())
  parentId         String
  classId          Int
  gradeId          Int
  birthday         DateTime
  accessCode       String?            @unique
  attendances      Attendance[]
  enrollments      CourseEnrollment[]
  progress         CourseProgress[]
  reviews          CourseReview[]
  notifications    Notification[]
  results          Result[]
  class            Class              @relation(fields: [classId], references: [id])
  grade            Grade              @relation(fields: [gradeId], references: [id])
  parent           Parent             @relation(fields: [parentId], references: [id])
  tickets          Ticket[]
}

model Subject {
  id      Int       @id @default(autoincrement())
  name    String    @unique
  lessons  Lesson[]
  teachers Teacher[]
}

model Teacher {
  id                String              @id
  username          String              @unique
  name              String
  surname           String
  email             String?             @unique
  phone             String?             @unique
  address           String
  img               String?
  bloodType         String
  sex               UserSex
  createdAt         DateTime            @default(now())
  birthday          DateTime
  accessCode        String?             @unique
  classes           Class[]
  courses           Course[]
  lessons           Lesson[]
  notifications     Notification[]
  attendances       TeacherAttendance[]
  tickets           Ticket[]
  subjects          Subject[]
}

model TeacherAttendance {
  id        Int      @id @default(autoincrement())
  date      DateTime
  present   Boolean
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
}

model Ticket {
  id            Int             @id @default(autoincrement())
  subject       String
  description   String
  status        TicketStatus    @default(OPEN)
  category      String          @default("other")
  createdAt     DateTime        @default(now())
  studentId     String?
  parentId      String?
  teacherId     String?
  parent        Parent?         @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student       Student?        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher       Teacher?        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  messages      TicketMessage[]
}

model TicketMessage {
  id                    Int                     @id @default(autoincrement())
  content               String
  messageType           String                  @default("TEXT")
  isRead                Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  ticketId              Int
  senderId              String
  senderRole            String
  replyToId             Int?
  ticket                Ticket                  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  replyTo               TicketMessage?          @relation("TicketMessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies               TicketMessage[]         @relation("TicketMessageReply")
  reactions             TicketMessageReaction[]
}

model TicketMessageReaction {
  id            Int           @id @default(autoincrement())
  messageId     Int
  userId        String
  emoji         String
  message       TicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

enum CourseStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

enum TicketStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum UserSex {
  MALE
  FEMALE
}

enum NotificationType {
  GENERIC
  TEACHER_CREATED
  TEACHER_UPDATED
  TEACHER_DELETED
  STUDENT_CREATED
  STUDENT_UPDATED
  STUDENT_DELETED
  PARENT_CREATED
  PARENT_UPDATED
  PARENT_DELETED
  GRADE_CREATED
  GRADE_UPDATED
  GRADE_DELETED
  CLASS_CREATED
  CLASS_UPDATED
  CLASS_DELETED
  LESSON_CREATED
  LESSON_UPDATED
  LESSON_DELETED
  COURSE_SUBMITTED
  COURSE_APPROVED
  COURSE_REJECTED
  COURSE_EXPIRED
  COURSE_UNEXPIRED
  COURSE_UPDATED
  COURSE_DELETED
  COURSE_ENROLLMENT
  EXAM_CREATED
  EXAM_UPDATED
  EXAM_DELETED
  ASSIGNMENT_CREATED
  ASSIGNMENT_UPDATED
  ASSIGNMENT_DELETED
  RESULT_POSTED
  RESULT_UPDATED
  RESULT_DELETED
  EVENT_CREATED
  EVENT_UPDATED
  EVENT_DELETED
  ANNOUNCEMENT_CREATED
  ANNOUNCEMENT_UPDATED
  ANNOUNCEMENT_DELETED
  TICKET_CREATED
  TICKET_UPDATED
  TICKET_DELETED
  COMMUNITY_POST_CREATED
  COMMUNITY_POST_LIKED
  COMMUNITY_POST_REPOSTED
  COMMUNITY_COMMENT_CREATED
  COMMUNITY_FOLLOWED
  COMMUNITY_REPORT_CREATED
  SERVER_MESSAGE
  SERVER_JOIN
  SERVER_ROLE_CHANGED
  SERVER_KICKED
  SERVER_MUTED
  FOLLOW_REQUEST_RECEIVED
  FOLLOW_REQUEST_ACCEPTED
  FOLLOW_REQUEST_DECLINED
  DM_REQUEST_RECEIVED
  DM_REQUEST_ACCEPTED
  DM_REQUEST_DECLINED
  DM_ACCESS_REVOKED
}

// ==================== COMMUNITY FEATURE MODELS ====================

model CommunityPost {
  id             String   @id @default(uuid())
  content        String   @db.Text
  authorId       String
  authorType     String   // student, teacher, parent, admin
  authorName     String
  authorImage    String?
  isRepost       Boolean  @default(false)
  originalPostId String?
  repostCount    Int      @default(0)
  likeCount      Int      @default(0)
  commentCount   Int      @default(0)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  author         UserCommunityProfile @relation(fields: [authorId], references: [userId])
  originalPost   CommunityPost?       @relation("Repost", fields: [originalPostId], references: [id])
  reposts        CommunityPost[]      @relation("Repost")
  likes          CommunityPostLike[]
  comments       CommunityComment[]
  reports        CommunityReport[]

  @@index([authorId])
  @@index([createdAt])
  @@index([originalPostId])
}

model CommunityComment {
  id          String   @id @default(uuid())
  content     String   @db.Text
  authorId    String
  authorType  String
  authorName  String
  authorImage String?
  postId      String
  parentId    String?
  likeCount   Int      @default(0)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post        CommunityPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent      CommunityComment?   @relation("CommentReplies", fields: [parentId], references: [id])
  replies     CommunityComment[]  @relation("CommentReplies")
  likes       CommunityCommentLike[]

  @@index([postId])
  @@index([parentId])
  @@index([authorId])
}

model CommunityFollow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    UserCommunityProfile @relation("Follows", fields: [followerId], references: [userId])
  following   UserCommunityProfile @relation("Followers", fields: [followingId], references: [userId])

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model UserCommunityProfile {
  userId                String   @id
  userType              String   // student, teacher, parent, admin
  username              String   @unique
  displayName           String?
  bio                   String?  @db.Text
  avatar                String?
  customAvatar          String?  // Custom avatar URL (GIF/image) - requires shop item
  bannerUrl             String?  // Profile banner URL (GIF/image) - requires shop item
  isPrivate             Boolean  @default(false)
  requireFollowApproval Boolean  @default(false) // If true, follows need approval
  showKarma             String   @default("everyone") // "nobody", "followers", "everyone"
  showAcademicProfile   String   @default("nobody") // "nobody", "followers", "everyone"
  karmaPoints           Int      @default(0)
  postCount             Int      @default(0)
  followerCount         Int      @default(0)
  followingCount        Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  posts                     CommunityPost[]
  follows                   CommunityFollow[] @relation("Follows")
  followers                 CommunityFollow[] @relation("Followers")
  karmaHistory              KarmaHistory[]
  sentFollowRequests        FollowRequest[] @relation("SentFollowRequests")
  receivedFollowRequests    FollowRequest[] @relation("ReceivedFollowRequests")
  sentDMAccessRequests      DMAccessRequest[] @relation("SentDMAccessRequests")
  receivedDMAccessRequests  DMAccessRequest[] @relation("ReceivedDMAccessRequests")

  @@index([username])
}

model KarmaHistory {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime @db.Date
  year        Int
  month       Int
  day         Int
  karmaEarned Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        UserCommunityProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([year, month])
  @@index([date])
}

model CommunityPostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
}

model CommunityCommentLike {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment   CommunityComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
}

model CommunityReport {
  id          String       @id @default(uuid())
  postId      String
  reporterId  String
  reason      String
  description String?
  status      ReportStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  post        CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([reporterId])
  @@index([status])
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

// ==================== GECX TOKEN SYSTEM MODELS ====================

model UserGecXBalance {
  id          String   @id @default(uuid())
  userId      String   @unique
  userType    String   // student, teacher, parent, admin
  balance     Int      @default(0)
  totalEarned Int      @default(0)
  totalSpent  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AvatarShopItem {
  id          String   @id @default(uuid())
  style       String   @unique // dicebear style name (e.g., "adventurer", "avataaars")
  name        String   // display name
  description String?
  cost        Int      // gecX cost
  category    String   // "basic", "standard", "premium" or custom
  isActive    Boolean  @default(true)
  previewSeed String   @default("Felix") // seed for preview image
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserAvatar {
  id          String   @id @default(uuid())
  userId      String
  style       String   // dicebear style
  seed        String   // unique seed for this user's avatar variation
  purchasedAt DateTime @default(now())
  cost        Int      // price paid

  @@unique([userId, style, seed])
  @@index([userId])
}

model UserEquippedAvatar {
  id             String   @id @default(uuid())
  userId         String   @unique
  academicStyle  String?  // equipped for academic profile
  academicSeed   String?  // specific variant seed
  communityStyle String?  // equipped for community profile
  communitySeed  String?  // specific variant seed
  updatedAt      DateTime @updatedAt
}

model GecXTransaction {
  id          String   @id @default(uuid())
  userId      String
  userType    String
  amount      Int      // positive for earn, negative for spend
  type        String   // "attendance", "result", "teacher_bonus", "parent_bonus", "purchase", "admin_grant"
  description String?
  relatedId   String?  // studentId for teacher/parent bonuses
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model GecXSettings {
  id                       String @id @default(uuid())
  defaultStartingBalance   Int    @default(0)
  
  // Student earning rates
  attendancePerDay         Int    @default(1)
  perfectAttendanceWeek    Int    @default(5)
  resultAbove95            Int    @default(25)
  resultAbove90            Int    @default(20)
  resultAbove85            Int    @default(15)
  resultAbove80            Int    @default(12)
  resultAbove70            Int    @default(8)
  resultAbove60            Int    @default(5)
  
  // Teacher earning (percentage of students' earnings)
  teacherAttendanceBonusPercent Int @default(10)
  teacherResultBonusPercent     Int @default(10)
  
  // Parent earning (percentage of children's earnings)
  parentAttendanceBonusPercent  Int @default(5)
  parentResultBonusPercent      Int @default(5)
  
  updatedAt DateTime @updatedAt
}

// ==================== KARMA SETTINGS MODEL ====================

model KarmaSettings {
  id                      String   @id @default(uuid())
  likeReceived            Int      @default(2)
  commentCreated          Int      @default(1)
  commentReceived         Int      @default(1)
  postCreated             Int      @default(2)
  repostReceived          Int      @default(10)
  perfectAttendanceWeek   Int      @default(5)
  attendancePerDay        Int      @default(1)
  resultAbove95           Int      @default(25)
  resultAbove90           Int      @default(20)
  resultAbove85           Int      @default(15)
  resultAbove80           Int      @default(12)
  resultAbove70           Int      @default(8)
  resultAbove60           Int      @default(5)
  messageSent             Int      @default(2)
  messageReactionReceived Int      @default(1)
  serverBumpReceived      Int      @default(5)
  updatedAt               DateTime @updatedAt
}

// ==================== SERVER FEATURE MODELS ====================

model Server {
  id             String          @id @default(uuid())
  name           String
  description    String?
  icon           String?
  iconUrl        String?         // Custom icon URL (shop item unlock)
  bannerUrl      String?         // Banner URL (shop item unlock)
  inviteCode     String          @unique
  isDiscoverable Boolean         @default(false)
  bumps          Int             @default(0)
  lastBumpedAt   DateTime?
  createdAt      DateTime        @default(now())
  createdById    String
  members        ServerMember[]
  channels       ServerChannel[]
  channelCategories ServerChannelCategory[] // Channel category sections
  emojis         ServerEmoji[]
  stickers       ServerSticker[]
  slotPurchases  ServerEmojiSlotPurchase[]
  customRoles    ServerRole[]    // New: custom roles
  settings       ServerSettings? // New: server settings
  reactionRoles  ReactionRole[] // New: reaction roles
  bans           ServerBan[]    // New: server bans

  @@index([inviteCode])
  @@index([isDiscoverable])
  @@index([bumps])
}

model ServerEmoji {
  id        String   @id @default(uuid())
  serverId  String
  name      String   // used as :name: in messages
  imageUrl  String
  addedById String
  createdAt DateTime @default(now())
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, name])
  @@index([serverId])
}

model ServerSticker {
  id        String   @id @default(uuid())
  serverId  String
  name      String
  imageUrl  String
  addedById String
  createdAt DateTime @default(now())
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, name])
  @@index([serverId])
}

model ServerEmojiSlotPurchase {
  id               String   @id @default(uuid())
  serverId         String
  planType         String   // "STARTER", "STANDARD", "PREMIUM"
  emojiSlotsAdded  Int
  stickerSlotsAdded Int
  cost             Int
  purchasedById    String
  createdAt        DateTime @default(now())
  server           Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([purchasedById])
}

model ServerMember {
  id          String     @id @default(uuid())
  serverId    String
  userId      String
  role        LegacyServerRole @default(MEMBER)
  roles       ServerMemberRole[] // New: multiple custom roles
  username    String
  displayName String
  joinedAt    DateTime   @default(now())
  isMuted     Boolean    @default(false)
  lastReadAt  DateTime   @default(now())
  sortOrder   Int        @default(0) // Manual sort position within role groups
  server      Server     @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
  @@index([userId])
}

enum LegacyServerRole {
  ADMIN
  MODERATOR
  MEMBER
}

model ServerChannel {
  id           String               @id @default(uuid())
  serverId     String
  categoryId   String?              // Nullable - uncategorized channels
  name         String
  order        Int                  @default(0)
  isPrivate    Boolean              @default(false) // If true, only specific roles can view
  createdAt    DateTime             @default(now())
  server       Server               @relation(fields: [serverId], references: [id], onDelete: Cascade)
  category     ServerChannelCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  messages     ServerMessage[]
  permissions  ChannelPermission[]  // Role-based visibility permissions

  @@index([serverId])
  @@index([categoryId])
}

// Channel categories - group channels into collapsible sections
model ServerChannelCategory {
  id        String          @id @default(uuid())
  serverId  String
  name      String
  order     Int             @default(0)
  createdAt DateTime        @default(now())
  server    Server          @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channels  ServerChannel[]

  @@index([serverId])
  @@index([order])
}

// Channel visibility permissions - which roles can view private channels
model ChannelPermission {
  id        String       @id @default(uuid())
  channelId String
  roleId    String       // null means everyone can view (public channel)
  channel   ServerChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  role      ServerRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([channelId, roleId])
  @@index([channelId])
  @@index([roleId])
}

model ServerMessage {
  id             String                  @id @default(uuid())
  content        String
  messageType    String                  @default("TEXT")
  commandKey     String?
  commandLabel   String?
  commandUrl     String?
  createdAt      DateTime                @default(now())
  senderId       String
  senderUsername String
  senderRole     String
  channelId      String
  replyToId      String?
  isRead         Boolean                 @default(false)
  channel        ServerChannel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  replyTo        ServerMessage?          @relation("ServerMessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        ServerMessage[]         @relation("ServerMessageReply")
  reactions      ServerMessageReaction[]
  poll           Poll?                   // Reuse existing Poll model

  @@index([channelId])
  @@index([channelId, createdAt])
  @@index([createdAt])
}

model ServerMessageReaction {
  id        String        @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  message   ServerMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

// ==================== CUSTOM ROLES SYSTEM ====================

model ServerRole {
  id          String   @id @default(uuid())
  serverId    String
  name        String
  color       String?  // Hex color code
  iconUrl     String?  // Custom role icon URL
  position    Int      // Role hierarchy position (higher = more powerful)
  permissions BigInt   @default(0) // Bit-field permissions
  hoist       Boolean  @default(false) // Display separately in member list
  mentionable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members     ServerMemberRole[]
  reactionRoles ReactionRole[]
  channelPermissions ChannelPermission[] // Which channels this role can view
  
  @@index([serverId])
  @@index([position])
}

model ServerMemberRole {
  id         String       @id @default(uuid())
  memberId   String
  roleId     String
  assignedAt DateTime     @default(now())
  assignedBy String?      // User ID who assigned the role
  member     ServerMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role       ServerRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  @@unique([memberId, roleId])
  @@index([memberId])
  @@index([roleId])
}

model ReactionRole {
  id          String     @id @default(uuid())
  serverId    String
  channelId   String
  messageId   String
  emoji       String     // Emoji or :emoji_name:
  roleId      String
  maxUses     Int?       // Limit how many users can get this role
  useCount    Int        @default(0)
  createdAt   DateTime   @default(now())
  createdById String
  server      Server     @relation(fields: [serverId], references: [id], onDelete: Cascade)
  role        ServerRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  @@index([serverId])
  @@index([channelId])
  @@index([messageId])
}

model ServerSettings {
  id                    String   @id @default(uuid())
  serverId              String   @unique
  memberSortOrder       String   @default("hierarchy_desc") // hierarchy_asc, hierarchy_desc, custom
  showRoleBadges        Boolean  @default(true)
  allowMemberReordering Boolean  @default(true)
  updatedAt             DateTime @updatedAt
  server                Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

model ServerBan {
  id          String   @id @default(uuid())
  serverId    String
  userId      String
  reason      String?
  bannedById  String
  bannedAt    DateTime @default(now())
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
  @@index([serverId])
  @@index([userId])
}

// ==================== USERNAME COLOR & PROFILE BG SHOP ====================

model UsernameColorShopItem {
  id          String   @id @default(uuid())
  name        String   // e.g., "Red - Light", "Blue - Neon"
  colorValue  String   // hex or CSS color value
  type        String   // "username" | "profileBg"
  shade       String   // "light", "dark", "neon", "normal"
  category    String   // "red", "blue", "green", etc.
  cost        Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownedBy     UserOwnedColor[]
  equippedAsUsername  UserEquippedColors[] @relation("UsernameColor")
  equippedAsProfileBg UserEquippedColors[] @relation("ProfileBgColor")
  equippedAsTheme     UserEquippedColors[] @relation("Theme")
  equippedAsNameplate UserEquippedColors[] @relation("Nameplate")

  @@index([type])
  @@index([category])
}

model UserOwnedColor {
  id          String   @id @default(uuid())
  userId      String
  colorItemId String
  purchasedAt DateTime @default(now())
  cost        Int

  colorItem   UsernameColorShopItem @relation(fields: [colorItemId], references: [id])

  @@unique([userId, colorItemId])
  @@index([userId])
}

model UserEquippedColors {
  id              String   @id @default(uuid())
  userId          String   @unique
  usernameColorId String?  // item ID from UsernameColorShopItem (null = use karma-based)
  profileBgColorId String? // item ID from UsernameColorShopItem (null = use karma-based)
  themeId         String?  // item ID for full app theme
  nameplateId     String?  // item ID for nameplate background
  updatedAt       DateTime @updatedAt

  usernameColorItem  UsernameColorShopItem? @relation("UsernameColor", fields: [usernameColorId], references: [id])
  profileBgColorItem UsernameColorShopItem? @relation("ProfileBgColor", fields: [profileBgColorId], references: [id])
  themeItem          UsernameColorShopItem? @relation("Theme", fields: [themeId], references: [id])
  nameplateItem      UsernameColorShopItem? @relation("Nameplate", fields: [nameplateId], references: [id])
}

// ==================== FOLLOW REQUESTS & DM ACCESS ====================

model FollowRequest {
  id          String   @id @default(uuid())
  requesterId String
  targetId    String
  status      FollowRequestStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester   UserCommunityProfile @relation("SentFollowRequests", fields: [requesterId], references: [userId], onDelete: Cascade)
  target      UserCommunityProfile @relation("ReceivedFollowRequests", fields: [targetId], references: [userId], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@index([targetId])
  @@index([status])
}

enum FollowRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

model DMAccessRequest {
  id          String   @id @default(uuid())
  requesterId String
  targetId    String
  status      DMAccessStatus @default(PENDING)
  message     String?  @db.Text // Optional message with request
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester   UserCommunityProfile @relation("SentDMAccessRequests", fields: [requesterId], references: [userId], onDelete: Cascade)
  target      UserCommunityProfile @relation("ReceivedDMAccessRequests", fields: [targetId], references: [userId], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@index([targetId])
  @@index([status])
}

enum DMAccessStatus {
  PENDING
  APPROVED
  DECLINED
  REVOKED
}

model DMAccessGrant {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  grantedAt DateTime @default(now())
  grantedBy String   // Who approved the request (userId)

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

// ==================== GLOBAL EMOJI & STICKER SHOP ====================

model GlobalEmoji {
  id          String   @id @default(uuid())
  name        String   @unique  // :name: syntax identifier
  imageUrl    String
  packId      String   // groups emojis into a purchasable pack (shopItemId reference)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  ownedBy     UserOwnedGlobalEmoji[]

  @@index([packId])
}

model GlobalSticker {
  id          String   @id @default(uuid())
  name        String   @unique  // :name: syntax identifier
  imageUrl    String
  packId      String   // groups stickers into a purchasable pack
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  ownedBy     UserOwnedGlobalSticker[]

  @@index([packId])
}

model UserOwnedGlobalEmoji {
  id          String      @id @default(uuid())
  userId      String
  emojiId     String
  purchasedAt DateTime    @default(now())
  emoji       GlobalEmoji @relation(fields: [emojiId], references: [id], onDelete: Cascade)

  @@unique([userId, emojiId])
  @@index([userId])
}

model UserOwnedGlobalSticker {
  id          String        @id @default(uuid())
  userId      String
  stickerId   String
  purchasedAt DateTime      @default(now())
  sticker     GlobalSticker @relation(fields: [stickerId], references: [id], onDelete: Cascade)

  @@unique([userId, stickerId])
  @@index([userId])
}
